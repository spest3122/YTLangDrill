{
    "manifest_version": 3,
    "name": "YouTube Timeline Pinner",
    "version": "1.0",
    "description": "Set custom video pins using number keys, overriding YouTube's default timeline jumps.",
    "permissions": ["storage"],
    "content_scripts": [
        {
            "matches": ["*://*.youtube.com/watch*"],
            "js": ["content.js"],
            "css": ["styles.css"],
            "run_at": "document_end"
        }
    ]
}
